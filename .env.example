# Nemotron-AB — root-level environment template
# 복사: `cp .env.example .env` 후 필요한 값만 수정하세요. .env 는 gitignore 대상입니다.

# --- 데이터베이스 -----------------------------------------------------------
# SQLite 파일 경로 (상대 경로는 저장소 루트 기준 — backend/ 에서 uvicorn 해도 동일). 미설정 시 nemotron_ab/app.sqlite3
APP_SQLITE_PATH=./nemotron_ab/app.sqlite3

# 모든 백엔드/워커가 따르는 통합 DB URL (Phase 3.2+). SQLite/PostgreSQL 동시 지원.
#   SQLite : sqlite:///./nemotron_ab/app.sqlite3  (상대 경로도 저장소 루트 기준)
#   Postgres: postgresql+psycopg://user:pw@host:port/dbname
#   비울 경우 APP_SQLITE_PATH → 저장소 기본 경로 순으로 폴백.
# Postgres 사용 시 `pip install -e .[postgres]` (psycopg[binary]) 가 필요합니다.
DATABASE_URL=

# CORS Origin 화이트리스트(쉼표 구분). 미설정 시 localhost:3000, 127.0.0.1:3000
CORS_ORIGINS=

# Next.js 서버가 FastAPI 로 프록시할 URL (rewrites 대상). Compose 환경에서는 http://api:8010
API_INTERNAL_URL=http://127.0.0.1:8010

# 설정 시 브라우저가 이 URL 로 직접 호출(프록시 미사용). 비우면 /_nemotron_api 사용 권장.
NEXT_PUBLIC_API_BASE_URL=

# Persona 검색 백엔드: 비우면 기본(Chroma + SentenceTransformer). `langchain_chroma` 도 가능.
PERSONA_RETRIEVE_BACKEND=

# 임베딩 모델 (Sentence-Transformers / HuggingFace 호환). 미지정 시 BAAI/bge-m3 (MIT, 1024d).
# 모델을 바꾸면 persona_db 를 재빌드해야 합니다.
EMBED_MODEL_NAME=

# LangChain 임베딩 디바이스: cuda 또는 cpu
CHROMA_LC_DEVICE=cpu

# 레거시 서브프로세스 경로용 Python 실행 파일 오버라이드. 미설정 시 ./venv/bin/python 또는 현재 인터프리터.
NEMOTRON_AB_PY=

# 워커 서브프로세스 타임아웃(초). 미설정 시 무제한.
AB_VALIDATOR_SUBPROCESS_TIMEOUT_SEC=
